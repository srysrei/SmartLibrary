<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.SmartLibrary" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_600</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/brand_600</item>
        <item name="colorOnPrimaryContainer">@color/white</item>
        <item name="colorSecondary">@color/brand_400</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/ink</item>
        <item name="android:colorBackground">@color/panel_bg</item>
        <item name="android:statusBarColor">@color/brand_700</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Rounded, filled primary button -->
    <style name="Widget.SmartLibrary.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">14dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="backgroundTint">@color/brand_600</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Outlined / secondary button -->
    <style name="Widget.SmartLibrary.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">14dp</item>
        <item name="android:paddingTop">13dp</item>
        <item name="android:paddingBottom">13dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/brand_600</item>
        <item name="strokeColor">@color/field_stroke</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- TextInputLayout, rounded outline -->
    <style name="Widget.SmartLibrary.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">13dp</item>
        <item name="boxCornerRadiusTopEnd">13dp</item>
        <item name="boxCornerRadiusBottomStart">13dp</item>
        <item name="boxCornerRadiusBottomEnd">13dp</item>
        <item name="boxStrokeColor">@color/brand_600</item>
        <item name="hintTextColor">@color/brand_600</item>
        <item name="boxBackgroundColor">@color/surface</item>
    </style>

    <style name="Widget.SmartLibrary.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="cardElevation">2dp</item>
        <item name="contentPadding">0dp</item>
    </style>

    <style name="Text.Title" parent="">
        <item name="android:textColor">@color/ink</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Text.Sub" parent="">
        <item name="android:textColor">@color/ink_sub</item>
        <item name="android:textSize">13sp</item>
    </style>
</resources>
