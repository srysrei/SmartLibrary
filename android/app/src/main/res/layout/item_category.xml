<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_card_white"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="13dp">

    <TextView
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_soft_circle"
        android:backgroundTint="@color/s_reverse_bg"
        android:gravity="center"
        android:text="🏷️"
        android:textSize="16sp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Category"
            android:textColor="@color/ink"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CAT_ID 0 · 0 books"
            android:textColor="@color/ink_sub"
            android:textSize="11.5sp" />
    </LinearLayout>

    <ImageView
        android:id="@+id/btnEdit"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginEnd="16dp"
        android:contentDescription="@string/category_edit_desc"
        android:src="@drawable/ic_edit"
        app:tint="@color/brand_600" />

    <ImageView
        android:id="@+id/btnDelete"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:contentDescription="@string/category_delete_desc"
        android:src="@drawable/ic_delete"
        app:tint="@color/bad" />
</LinearLayout>
